def start_motor_task(target, *args):
    # Run motor control calls in daemon threads so HTTP requests return immediately.
    def _run_task():
        try:
            target(*args)
        except Exception:
            app.logger.exception('Motor task failed: %s', target.__name__)

    worker = Thread(target=_run_task, daemon=True)
    worker.start()


