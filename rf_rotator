# encoder
ENCODER_BITS = 12
ENCODER_PREC = 2 ** ENCODER_BITS
ENCODER_SPI_BUS = int(os.environ.get('ENCODER_SPI_BUS', '0'))
ENCODER_SPI_DEVICE = int(os.environ.get('ENCODER_SPI_DEVICE', '0'))
ENCODER_SPI_MODE = int(os.environ.get('ENCODER_SPI_MODE', '0'))
ENCODER_SPI_HZ = int(os.environ.get('ENCODER_SPI_HZ', '500000'))
ENCODER_BYTE_DELAY_US = int(os.environ.get('ENCODER_BYTE_DELAY_US', '3'))
ENCODER_MAX_RETRIES = int(os.environ.get('ENCODER_MAX_RETRIES', '3'))
ENCODER_REQUIRE_CHECKSUM = os.environ.get('ENCODER_REQUIRE_CHECKSUM', '0') == '1'
encoder_error_logged = False
gpio_error_logged = False
encoder_checksum_warning_logged = False


def log_encoder_access_error(exc):
    global encoder_error_logged
    if not encoder_error_logged:
        app.logger.error(
            'Encoder SPI access failed. Enable SPI and grant /dev/spidev permissions: %s',
            exc
        )
        encoder_error_logged = True


def log_gpio_access_error(exc):
    global gpio_error_logged
    if not gpio_error_logged:
        app.logger.error(
            'GPIO access failed. Add your user to gpio group or run with sudo: %s',
            exc
        )
        gpio_error_logged = True

# Initializes a encoder object
def initEncoder():
    try:
        encoder = spidev.SpiDev()
        encoder.open(ENCODER_SPI_BUS, ENCODER_SPI_DEVICE)
        encoder.max_speed_hz = ENCODER_SPI_HZ
        encoder.mode = ENCODER_SPI_MODE
        encoder.bits_per_word = 8
        return encoder
    except (PermissionError, FileNotFoundError, OSError) as exc:
        log_encoder_access_error(exc)
        return None


def verifyEncoderChecksum(message):
    # AMT22 checksum is the inverted XOR parity across pairs of bits.
    checksum = 0x3
    for i in range(0, 14, 2):
        checksum ^= (message >> i) & 0x3
    return checksum == (message >> 14)


def parseEncoderPosition(raw):
    position = raw & 0x3FFF
    if ENCODER_BITS == 12:
        position >>= 2
    return position


# Prompts encoder to send two byte position
# trims the two bytes -> 00XXXXXX XXXXXX00
# -> XXXXXX XXXXXX (12 bits useful data)
# combines and returns as angle
def readEncoder(encoder):
    global encoder_checksum_warning_logged
    if encoder is None:
        return None

    last_raw = None
    for _ in range(ENCODER_MAX_RETRIES):
        # AMT22 position read: transfer 0x00 0x00 in one CS transaction.
        rx = encoder.xfer2([0x00, 0x00], ENCODER_SPI_HZ, ENCODER_BYTE_DELAY_US)
        if len(rx) != 2:
            continue

        raw = (rx[0] << 8) | rx[1]
        last_raw = raw
        if not verifyEncoderChecksum(raw):
            # AMT22 requires small timing gaps between transfers.
            time.sleep(0.00001)
            continue

        return parseEncoderPosition(raw)

    if not ENCODER_REQUIRE_CHECKSUM and last_raw is not None and last_raw not in (0x0000, 0xFFFF):
        if not encoder_checksum_warning_logged:
            app.logger.warning(
                'Encoder checksum validation failed; using raw fallback values. '
                'Set ENCODER_REQUIRE_CHECKSUM=1 to enforce strict mode.'
            )
            encoder_checksum_warning_logged = True
        return parseEncoderPosition(last_raw)

    return None


# Give degrees, converts to binary 12-bit
def convertToCode(deg):
    return int(round(deg / 360.0 * ENCODER_PREC))


# Give binary 12-bit, converts to degree
def convertToDegree(code):
    return code / ENCODER_PREC * 360.0


# Set current physical position as the 0 angle
def resetEncoder():
    encoder = initEncoder()
    if encoder is None:
        return False
    # AMT22 set-zero command is an extended command: 0x00 then 0x70.
    encoder.xfer2([0x00, 0x70])
    time.sleep(0.25)
    encoder.close()
    return True

# Retrieves code from encoder without the need
# of encoder object
def retrieveCode():
    encoder = initEncoder()
    if encoder is None:
        return None
    try:
        return readEncoder(encoder)
    finally:
        encoder.close()


def retrieveAngle():
    code = retrieveCode()
    if code is None:
        return None
    return convertToDegree(code)


def readEncoderDiagnostics(sample_count=6):
    encoder = initEncoder()
    if encoder is None:
        return None

    try:
        samples = []
        for _ in range(sample_count):
            rx = encoder.xfer2([0x00, 0x00], ENCODER_SPI_HZ, ENCODER_BYTE_DELAY_US)
            raw = (rx[0] << 8) | rx[1] if len(rx) == 2 else None
            valid = verifyEncoderChecksum(raw) if raw is not None else False
            parsed = parseEncoderPosition(raw) if raw is not None else None
            samples.append({
                'rx': rx,
                'raw': raw,
                'checksum_valid': valid,
                'position': parsed,
            })
            time.sleep(0.01)

        return {
            'spi_bus': ENCODER_SPI_BUS,
            'spi_device': ENCODER_SPI_DEVICE,
            'spi_mode': ENCODER_SPI_MODE,
            'spi_hz': ENCODER_SPI_HZ,
            'byte_delay_us': ENCODER_BYTE_DELAY_US,
            'require_checksum': ENCODER_REQUIRE_CHECKSUM,
            'samples': samples,
        }
    finally:
        encoder.close()


def scanEncoderCandidates(sample_count=4):
    results = []
    for device in (0, 1):
        for mode in (0, 1, 2, 3):
            entry = {
                'spi_bus': ENCODER_SPI_BUS,
                'spi_device': device,
                'spi_mode': mode,
                'spi_hz': ENCODER_SPI_HZ,
                'byte_delay_us': ENCODER_BYTE_DELAY_US,
            }

            encoder = spidev.SpiDev()
            try:
                encoder.open(ENCODER_SPI_BUS, device)
                encoder.max_speed_hz = ENCODER_SPI_HZ
                encoder.mode = mode
                encoder.bits_per_word = 8

                raws = []
                checksum_valid_count = 0
                for _ in range(sample_count):
                    rx = encoder.xfer2([0x00, 0x00], ENCODER_SPI_HZ, ENCODER_BYTE_DELAY_US)
                    raw = (rx[0] << 8) | rx[1] if len(rx) == 2 else None
                    if raw is not None:
                        raws.append(raw)
                        if verifyEncoderChecksum(raw):
                            checksum_valid_count += 1
                    time.sleep(0.003)

                unique_raws = sorted(list(set(raws)))
                entry.update({
                    'raw_samples': raws,
                    'unique_raw_values': unique_raws,
                    'all_zero': len(unique_raws) == 1 and unique_raws[0] == 0 if unique_raws else False,
                    'all_ones': len(unique_raws) == 1 and unique_raws[0] == 0xFFFF if unique_raws else False,
                    'changing': len(unique_raws) > 1,
                    'checksum_valid_count': checksum_valid_count,
                })
            except Exception as exc:
                entry['error'] = str(exc)
            finally:
                try:
                    encoder.close()
                except Exception:
                    pass

            results.append(entry)

    return {'candidates': results}


