class WaveshareStepper:
    _MICROSTEP_MAP = {
        'fullstep': (0, 0, 0),
        'halfstep': (1, 0, 0),
        '1/4step': (0, 1, 0),
        '1/8step': (1, 1, 0),
        '1/16step': (0, 0, 1),
        '1/32step': (1, 0, 1),
    }

    def __init__(self, dir_pin, step_pin, enable_pin, mode_pins,
                 control_mode='hardward', step_format='1/16step',
                 enable_active_high=True, invert_dir=False,
                 pulse_width_sec=0.001):
        self.dir_pin = dir_pin
        self.step_pin = step_pin
        self.enable_pin = enable_pin
        self.mode_pins = mode_pins
        self.enable_active_high = enable_active_high
        self.invert_dir = invert_dir
        self.pulse_width_sec = pulse_width_sec

        GPIO.setmode(GPIO.BCM)
        GPIO.setwarnings(False)
        GPIO.setup(self.dir_pin, GPIO.OUT)
        GPIO.setup(self.step_pin, GPIO.OUT)
        GPIO.setup(self.enable_pin, GPIO.OUT)
        GPIO.setup(self.mode_pins, GPIO.OUT)

        self._set_microstep(control_mode, step_format)
        self.release()

    def _set_enabled(self, enabled):
        if self.enable_active_high:
            GPIO.output(self.enable_pin, 1 if enabled else 0)
        else:
            GPIO.output(self.enable_pin, 0 if enabled else 1)

    def _set_microstep(self, control_mode, step_format):
        if control_mode == 'softward':
            pins = self._MICROSTEP_MAP.get(step_format)
            if pins is None:
                raise ValueError(f'Unsupported microstep format: {step_format}')
            GPIO.output(self.mode_pins, pins)

    def onestep(self, style=None, direction=1):
        # Keep compatibility with previous direction semantics.
        # 1 = backward, 2 = forward
        self._set_enabled(True)
        dir_level = 1 if direction == 1 else 0
        if self.invert_dir:
            dir_level = 0 if dir_level else 1
        GPIO.output(self.dir_pin, dir_level)
        GPIO.output(self.step_pin, 1)
        time.sleep(self.pulse_width_sec)
        GPIO.output(self.step_pin, 0)
        time.sleep(self.pulse_width_sec)

    def release(self):
        self._set_enabled(False)


def microstep_format_from_steps(microsteps):
    mapping = {
        1: 'fullstep',
        2: 'halfstep',
        4: '1/4step',
        8: '1/8step',
        16: '1/16step',
        32: '1/32step',
    }
    return mapping.get(microsteps, '1/16step')


# Creates and returns rotator object
def initRotator():
    rotator = WaveshareStepper(
        dir_pin=WS_DIR_PIN,
        step_pin=WS_STEP_PIN,
        enable_pin=WS_ENABLE_PIN,
        mode_pins=WS_MODE_PINS,
        control_mode=WS_CONTROL_MODE,
        step_format=microstep_format_from_steps(MICROSTEPS),
        enable_active_high=WS_ENABLE_ACTIVE_HIGH,
        invert_dir=WS_INVERT_DIR,
        pulse_width_sec=WS_STEP_PULSE_SEC,
    )
    return rotator


# Create file_handler for file to record
# angle and time
def getRecordFile():
    file_name = os.path.dirname(os.path.realpath(__file__))
    file_name = file_name + "/AntennaAngle" + \
        time.strftime('_%H_%M_%S') + ".txt"
    file_handler = open(file_name, "w+")
    return file_handler


# Moves the antenna to its current physical 0 angle
def resetRotator():
    rotator = initRotator()
    encoder = initEncoder()
    if encoder is None:
        rotator.release()
        return
    sec_per_step = 60.0 / (REV_STEPS * RPM * MICROSTEPS)
    next_step = time.monotonic()
    step_count = 0
    while True:
        rotator.onestep(direction=2 - 2)
        step_count += 1
        next_step += sec_per_step
        remaining = next_step - time.monotonic()
        if remaining > 0:
            time.sleep(remaining)
        if step_count % MICROSTEPS == 0:
            if (abs(readEncoder(encoder) - ENCODER_PREC / 2) >
                    (ENCODER_PREC / 2 - MICROSTEPS)):
                break
    rotator.release()
    encoder.close()


# Rotates the rotator at the set RPM for X seconds and direction
# Records if needed
def rotateTillSeconds(sec, record, direction):
    rotator = initRotator()
    encoder = initEncoder() if record else None
    tic = time.time()
    if record:
        if encoder is None:
            app.logger.warning('Record requested, but encoder is unavailable. Continuing without recording.')
            record = False
            record_file = None
        else:
            record_file = getRecordFile()
            record_file.write("Start recording at %10.7f \n\n" % tic)
    else:
        record_file = None

    sec_per_step = 60.0 / (REV_STEPS * RPM * MICROSTEPS)
    next_step = time.monotonic()
    step_count = 0
    while (time.time() - tic) < sec:
        rotator.onestep(direction=2 - direction)
        step_count += 1
        next_step += sec_per_step
        remaining = next_step - time.monotonic()
        if remaining > 0:
            time.sleep(remaining)
        if record_file and encoder and step_count % MICROSTEPS == 0:
            record_file.write("%10.7f" % (time.time() - tic))
            record_file.write(" %10.7f\n" % convertToDegree(readEncoder(encoder)))

    if record_file:
        record_file.close()
    rotator.release()
    if encoder:
        encoder.close()


# Rotates the rotator at the set RPM for X degrees and direction
# Records if needed
def rotateTillDegrees(deg, record, direction):
    rotator = initRotator()
    encoder = initEncoder()
    if encoder is None:
        rotator.release()
        app.logger.warning('Cannot rotate by degrees without encoder feedback.')
        return
    tic = time.time()
    if record:
        record_file = getRecordFile()
        record_file.write("Start recording at %10.7f \n\n" % tic)
    else:
        record_file = None

    sec_per_step = 60.0 / (REV_STEPS * RPM * MICROSTEPS)
    next_step = time.monotonic()
    total = 0
    memory1 = convertToDegree(readEncoder(encoder))
    step_count = 0
    while total < (deg - 2):
        rotator.onestep(direction=2 - direction)
        step_count += 1
        next_step += sec_per_step
        remaining = next_step - time.monotonic()
        if remaining > 0:
            time.sleep(remaining)
        if step_count % MICROSTEPS == 0:
            memory2 = convertToDegree(readEncoder(encoder))
            delta = abs(memory1 - memory2)
            if delta > 100:
                delta = 360 - delta
            memory1 = memory2
            total += delta
            if record_file:
                record_file.write("%10.7f" % (time.time() - tic))
                record_file.write(" %10.7f\n" % memory2)

    if record_file:
        record_file.close()
    rotator.release()
    encoder.close()


